# Base URL of the upstream API consumed through the Modern.js BFF layer.
WOOT_INDEX_API_BASE_URL=http://localhost:3200

# Admin key forwarded to the upstream API on every BFF request. Required.
WOOT_INDEX_API_ADMIN_KEY="change-me-to-a-strong-random-secret"

# Local port used by the Modern.js development server.
PORT=3300